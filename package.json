{
  "name": "insta-checkout",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "packages/i18n",
    "apps/backend",
    "apps/checkout",
    "apps/landing",
    "apps/admin"
  ],
  "scripts": {
    "dev": "npm run dev:landing",
    "db:up": "docker compose up -d mongodb",
    "db:down": "docker compose down",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:backend:docker": "npx pnpm --filter backend dev",
    "dev:checkout": "npm run dev --workspace=checkout",
    "dev:landing": "npm run dev --workspace=landing",
    "dev:admin": "npm run dev --workspace=admin",
    "build": "npm run build --workspaces",
    "build:backend": "npm run build --workspace=backend",
    "build:checkout": "npm run build --workspace=checkout",
    "build:landing": "npm run build --workspace=landing",
    "build:admin": "npm run build --workspace=admin",
    "lint": "npm run lint --workspaces",
    "firebase:deploy": "firebase deploy --only storage"
  },
  "devDependencies": {
    "firebase-tools": "^13.0.0"
  }
}
