# MongoDB connection string (add /DATABASE_NAME before ? to specify db, e.g. ...mongodb.net/test?appName=...)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=your-app

# Database name (used when not in URI). Default: test. Must match where onboarding writes sellers.
# MONGODB_DB_NAME=test

# Server port (default: 4000)
PORT=4000

# Frontend URL for CORS (e.g. http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# Optional: comma-separated extra CORS origins (e.g. https://app.example.com)
# CORS_ORIGINS=

# Base URL for generated checkout links. When unset:
# - production: https://pay.instacheckouteg.com
# - local dev: http://localhost:3001
# CHECKOUT_BASE_URL=http://localhost:3001
